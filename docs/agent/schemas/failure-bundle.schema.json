{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/omarespejel/uc/docs/agent/schemas/failure-bundle.schema.json",
  "title": "uc FailureBundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at_epoch_ms",
    "command",
    "redacted_environment",
    "error"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "generated_at_epoch_ms": { "type": "number", "minimum": 0 },
    "command": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "manifest_path": { "type": ["string", "null"] },
    "workspace_root": { "type": ["string", "null"] },
    "original_cwd": { "type": ["string", "null"] },
    "manifest_hash": { "type": ["string", "null"] },
    "lockfile_hash": { "type": ["string", "null"] },
    "selected_support": {
      "anyOf": [
        { "$ref": "native-support-report.schema.json" },
        { "type": "null" }
      ]
    },
    "redacted_environment": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "error": { "type": "string" },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
