+const UC_CAIRO214_SIZE_TRACE_MAX_KEYS: usize = 65_536;
+
+struct UcCairo214SizeTraceConfig {
+    path: Option<PathBuf>,
+    names: bool,
+}
+
+static UC_CAIRO214_SIZE_TRACE_CONFIG: OnceLock<UcCairo214SizeTraceConfig> = OnceLock::new();
+static UC_CAIRO214_SIZE_TRACE_COUNTS: OnceLock<Mutex<HashMap<String, u64>>> =
+    OnceLock::new();
+static UC_CAIRO214_SIZE_TRACE_WRITE_LOCK: OnceLock<Mutex<()>> = OnceLock::new();
+
+fn uc_cairo214_size_trace_config() -> &'static UcCairo214SizeTraceConfig {
+    UC_CAIRO214_SIZE_TRACE_CONFIG.get_or_init(|| UcCairo214SizeTraceConfig {
+        path: std::env::var_os("UC_CAIRO214_SIZE_TRACE").map(PathBuf::from),
+        names: std::env::var_os("UC_CAIRO214_SIZE_TRACE_NAMES").is_some(),
+    })
+}
+
+fn uc_cairo214_size_trace_hash(text: &str) -> u64 {
+    let mut hash = 0xcbf29ce484222325u64;
+    for byte in text.as_bytes() {
+        hash ^= u64::from(*byte);
+        hash = hash.wrapping_mul(0x100000001b3);
+    }
+    hash
+}
+
+fn uc_cairo214_size_trace_preview(text: &str) -> String {
+    let mut preview = text.chars().take(160).collect::<String>();
+    if preview.len() < text.len() {
+        preview.push_str("...");
+    }
+    preview
+}
+
+fn uc_cairo214_size_trace_event(
+    db: &dyn Database,
+    event: &str,
+    function_id: ConcreteFunctionWithBodyId<'_>,
+) {
+    let config = uc_cairo214_size_trace_config();
+    let Some(path) = config.path.as_ref() else {
+        return;
+    };
+    let function_key = format!("{:p}:{:?}", db as *const dyn Database as *const (), function_id.get_internal_id());
+    let key = format!("{event}\t{function_key}");
+    let counts = UC_CAIRO214_SIZE_TRACE_COUNTS
+        .get_or_init(|| Mutex::new(HashMap::new()));
+    let Ok(mut counts) = counts.lock() else {
+        return;
+    };
+    let count = if let Some(count) = counts.get_mut(&key) {
+        *count = count.saturating_add(1);
+        *count
+    } else {
+        if counts.len() >= UC_CAIRO214_SIZE_TRACE_MAX_KEYS {
+            return;
+        }
+        counts.insert(key, 1);
+        1
+    };
+    drop(counts);
+    if count != 1 && !count.is_power_of_two() {
+        return;
+    }
+    let function_label = if config.names {
+        let function_path = function_id.full_path(db);
+        format!(
+            "{:016x}:{}",
+            uc_cairo214_size_trace_hash(&function_path),
+            uc_cairo214_size_trace_preview(&function_path)
+        )
+    } else {
+        function_key.clone()
+    };
+    let write_lock = UC_CAIRO214_SIZE_TRACE_WRITE_LOCK.get_or_init(|| Mutex::new(()));
+    let Ok(_write_guard) = write_lock.lock() else {
+        return;
+    };
+    let Ok(mut file) = std::fs::OpenOptions::new().create(true).append(true).open(path) else {
+        return;
+    };
+    let _ = writeln!(file, "{event}\t{count}\t{function_key}\t{function_label}");
+}
