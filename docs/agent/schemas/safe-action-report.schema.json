{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/omarespejel/uc/docs/agent/schemas/safe-action-report.schema.json",
  "title": "uc SafeActionReport",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "generated_at_epoch_ms",
    "action",
    "dry_run",
    "command",
    "executed",
    "stdout",
    "stderr"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "generated_at_epoch_ms": { "type": "number" },
    "action": { "type": "string" },
    "dry_run": { "type": "boolean" },
    "command": { "type": "array", "items": { "type": "string" } },
    "executed": { "type": "boolean" },
    "exit_code": { "type": "integer" },
    "stdout": { "type": "string" },
    "stderr": { "type": "string" },
    "blocked_reason": { "type": "string" }
  }
}
