{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/omarespejel/uc/docs/agent/schemas/benchmark-report.schema.json",
  "title": "uc BenchmarkReport",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "summary", "cases"],
  "properties": {
    "schema_version": { "const": 1 },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": ["support_matrix"],
      "properties": {
        "support_matrix": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "native_supported",
            "native_unsupported",
            "fallback_used",
            "build_failed"
          ],
          "properties": {
            "native_supported": { "type": "integer", "minimum": 0 },
            "native_unsupported": { "type": "integer", "minimum": 0 },
            "fallback_used": { "type": "integer", "minimum": 0 },
            "build_failed": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "cases": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    }
  }
}
